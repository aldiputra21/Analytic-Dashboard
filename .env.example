# ============================================================
# Financial Ratio Monitoring System - Environment Configuration
# Copy this file to .env.local and fill in your values.
# ============================================================

# --- Application ---
NODE_ENV=development
PORT=5000
APP_URL=http://localhost:5000

# --- Database ---
# Path to the SQLite database file
DATABASE_URL=./finance.db

# --- JWT Authentication (Requirements: 9.6, 9.7) ---
# REQUIRED: Change this to a strong random secret in production
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
FRS_JWT_SECRET=change-me-to-a-strong-random-secret-in-production
FRS_JWT_EXPIRES_IN=30m

# --- Backup & Recovery (Requirements: 14.1, 14.3) ---
# Directory where encrypted backups are stored
BACKUP_LOCATION=./backups
# AES-256 encryption key for backups (64 hex chars = 32 bytes)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BACKUP_ENCRYPTION_KEY=change-me-to-a-64-char-hex-string-for-aes256-encryption

# --- SMTP Email (Requirements: 10.6) ---
# Used for sending scheduled reports via email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=reports@example.com
SMTP_PASSWORD=your-smtp-password

# --- Cache (Requirements: 12.4) ---
# TTL in milliseconds for ratio calculation cache (default: 5 minutes)
CACHE_TTL=300000

# --- Rate Limiting ---
# Max auth attempts per 15-minute window
RATE_LIMIT_AUTH_MAX=20

# --- Gemini AI (optional) ---
GEMINI_API_KEY=
